APIMART_API_KEY=your_apimart_api_key_here
APIMART_BASE_URL=https://api.apimart.ai/v1
# 本地开发需要代理时填写；Vercel 生产环境不要配置本机 127.0.0.1/localhost 代理。
APIMART_PROXY_URL=http://127.0.0.1:7890

MENGFACTORY_API_KEY=your_mengfactory_api_key_here
MENGFACTORY_BASE_URL=https://api.mengfactory.cn

# Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_GENERATED_IMAGES_BUCKET=generated-images

# Used by /api/cron/sync-apimart-tasks
CRON_SECRET=replace_with_a_long_random_secret
APIMART_SYNC_BATCH_SIZE=20
